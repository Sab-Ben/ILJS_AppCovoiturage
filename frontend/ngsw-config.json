{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-trajets",
      "urls": [
        "/api/trajets/**",
        "/api/users/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "3d",
        "timeout": "5s"
      }
    },
    {
      "name": "map-tiles",
      "urls": [
        "https://*.tile.openstreetmap.org/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 5000,
        "maxAge": "10d"
      }
    }
  ]
}